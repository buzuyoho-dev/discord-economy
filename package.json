{
  "name": "discord-economy",
  "version": "0.1.0",
  "private": true,
  "description": "디스코드 서버 전용 가상 포인트 경제 시스템 봇",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma migrate deploy && npm run deploy-commands && node dist/index.js",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "node-cron": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}

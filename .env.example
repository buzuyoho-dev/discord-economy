# 디스코드 봇 토큰 (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# 슬래시 커맨드 등록용 애플리케이션(클라이언트) ID
DISCORD_CLIENT_ID=

# 개발 중 슬래시 커맨드를 특정 서버에만 즉시 등록하기 위한 길드 ID (선택)
DISCORD_GUILD_ID=

# 주간 환원 이벤트 발생 시 공개 안내 메시지를 보낼 채널 ID (선택, 미설정 시 안내 메시지를 보내지 않음)
REBATE_ANNOUNCEMENT_CHANNEL_ID=

# 베팅 개설/참가/마감/정산 기록을 자동으로 남길 채널 ID (선택, 미설정 시 기록을 남기지 않음 - 실 운영 전 반드시 설정 권장)
BET_LOG_CHANNEL_ID=

# /포인트지급(관리자 무상 지급) 명령어를 사용할 수 있는 유일한 디스코드 유저 ID (선택, 미설정 시 누구도 사용 불가)
ADMIN_DISCORD_ID=

# /도박 명령어 활성화 여부 (선택, "true"가 아니면 비활성화 - 점검 중 안내만 표시). 장애/버그 대응용 긴급 차단 스위치
GAMBLE_ENABLED=

# Prisma SQLite 연결 문자열
# 로컬 개발: file:./dev.db
# Railway 배포 시: Volume을 /app/data에 마운트하고 DATABASE_URL="file:/app/data/prod.db"로 설정 (Railway 프로젝트 환경변수에 직접 입력, 이 파일에는 적용되지 않음)
DATABASE_URL="file:./dev.db"

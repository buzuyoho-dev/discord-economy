generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INITIAL
  ATTENDANCE
  BET
  TRANSFER
  LOAN
  TAX
  REBATE
  GAMBLE_WIN
  GAMBLE_LOSE
  ADMIN_GRANT
  GAMBLE_ROLLBACK
  ADMIN_RESET
  GAMBLE_EXTRA_PURCHASE
  LOTTERY_PURCHASE
  LOTTERY_WIN
  LOTTERY_TAX
  SETTLEMENT_CORRECTION
  BLACKJACK_BET
  BLACKJACK_WIN
  BLACKJACK_LOSE
  BLACKJACK_PUSH
  RPS_BET
  RPS_WIN
  RPS_LOSE
  RPS_VOID
  MINIGAME_PLAY_GRANT
  LOAN_VOID_REFUND
  LOAN_VOID_FEE_REFUND
  LOAN_VOID_HOUSE_ABSORB
}

model User {
  discordId    String        @id
  balance      Int           @default(0)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id           Int             @id @default(autoincrement())
  userId       String
  user         User            @relation(fields: [userId], references: [discordId])
  type         TransactionType
  amount       Int
  balanceAfter Int
  description  String?
  createdAt    DateTime        @default(now())

  @@index([userId])
}

model House {
  id                 String    @id
  balance            Int       @default(0)
  lastRebateBalance  Int       @default(0)
  lastRebateAt       DateTime?
}

// 싱글톤 - row는 항상 1개("SINGLETON")만 존재한다.
model EconomyConfig {
  id              String   @id @default("SINGLETON")
  rebateRate      Float    @default(0.05)
  lowerTierWeight Float    @default(1.5)
  updatedAt       DateTime @updatedAt
}

// 유저 노출명: "베팅2배쿠폰"
model BettingDoubleCoupon {
  id          String    @id @default(cuid())
  userId      String
  issuedAt    DateTime  @default(now())
  expiresAt   DateTime
  usedAt      DateTime?
  usedInBetId Int?

  @@index([userId])
}

model HouseTransaction {
  id           Int             @id @default(autoincrement())
  type         TransactionType
  amount       Int
  balanceAfter Int
  description  String?
  occurredAt   DateTime        @default(now())
}

enum BetStatus {
  OPEN
  CLOSED
  SETTLED
  VOID
  VOIDED
}

// LEGACY_MODE1: 통합 이전에 이미 만들어진 균등금액 베팅 (기존 로직으로만 정산됨).
// UNIFIED: 이 필드 도입 이후 새로 생성되는 비례 배당 자유배팅.
enum BetMode {
  LEGACY_MODE1
  UNIFIED
}

model Bet {
  id              Int         @id @default(autoincrement())
  creatorId       String
  title           String
  mode            BetMode     @default(LEGACY_MODE1)
  amount          Int?
  status          BetStatus   @default(OPEN)
  winningOptionId Int?
  createdAt       DateTime    @default(now())
  closedAt        DateTime?
  settledAt       DateTime?
  options         BetOption[]
  entries         BetEntry[]
}

model BetOption {
  id      Int        @id @default(autoincrement())
  betId   Int
  bet     Bet        @relation(fields: [betId], references: [id])
  label   String
  entries BetEntry[]

  @@index([betId])
}

model BetEntry {
  id       Int       @id @default(autoincrement())
  betId    Int
  bet      Bet       @relation(fields: [betId], references: [id])
  userId   String
  optionId Int
  option   BetOption @relation(fields: [optionId], references: [id])
  amount   Int?
  payout   Int?
  couponId String?
  joinedAt DateTime  @default(now())

  @@unique([betId, userId])
  @@index([betId])
}

enum Mode2BetStatus {
  OPEN
  CLOSED
  SETTLED
}

enum Mode2Side {
  A
  B
}

model Mode2Bet {
  id          Int             @id @default(autoincrement())
  creatorId   String
  title       String
  sideALabel  String
  sideBLabel  String
  status      Mode2BetStatus  @default(OPEN)
  winningSide Mode2Side?
  createdAt   DateTime        @default(now())
  closedAt    DateTime?
  settledAt   DateTime?
  entries     Mode2Entry[]
}

model Mode2Entry {
  id       Int       @id @default(autoincrement())
  betId    Int
  bet      Mode2Bet  @relation(fields: [betId], references: [id])
  userId   String
  side     Mode2Side
  amount   Int
  joinedAt DateTime  @default(now())

  @@unique([betId, userId])
  @@index([betId])
}

enum LoanStatus {
  ACTIVE
  REPAID
  VOIDED
  PENDING
}

model Loan {
  id         Int        @id @default(autoincrement())
  lenderId   String
  borrowerId String
  principal  Int
  dueAt      DateTime
  status     LoanStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  repaidAt   DateTime?
  voidedAt   DateTime?

  @@index([borrowerId])
  @@index([lenderId])
}

model LotteryTicket {
  id           String   @id @default(cuid())
  userId       String
  chosenNumber Int
  amount       Int
  drawDate     DateTime
  purchasedAt  DateTime @default(now())
  settled      Boolean  @default(false)

  @@unique([userId, drawDate])
}

model LotteryState {
  id              Int @id @default(1)
  currentJackpot  Int @default(0)
  nextRoundNumber Int @default(1)
}

model LotteryStatusMessage {
  id               String   @id @default(cuid())
  drawDate         DateTime @unique
  roundNumber      Int
  channelMessageId String
  createdAt        DateTime @default(now())
}

// 💡 미니게임(블랙잭, 추후 다른 미니게임)의 "하루 몇 번 했는지" 횟수만 기록하는 테이블.
// gameType별로 카운트가 완전히 분리되어서, 블랙잭을 5번 다 써도 다른 미니게임엔 영향 없음.
model MinigamePlayLog {
  id       String   @id @default(cuid())
  userId   String
  gameType String // "BLACKJACK", 추후 "RPS" 등 추가 예정
  count    Int      @default(0)
  playDate DateTime // KST 자정 기준 날짜값 (kstMidnightUtc로 계산)

  @@unique([userId, gameType, playDate])
}
